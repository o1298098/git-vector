# Git 托管 Webhook（按你用的平台填对应密钥；不填则跳过验签，仅适合内网调试）
#GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret
# GitHub：仓库 Settings → Webhooks → Secret（验签 X-Hub-Signature-256）
# GITHUB_WEBHOOK_SECRET=
# Gitea：仓库 Webhooks → Secret（验签 X-Gitea-Signature）
# GITEA_WEBHOOK_SECRET=

# 私有 HTTPS 克隆：GIT_HTTPS_TOKEN 优先于 GITLAB_ACCESS_TOKEN；GitHub 常配合 GIT_HTTPS_USERNAME=x-access-token
GITLAB_ACCESS_TOKEN=glpat-xxxx
# GIT_HTTPS_TOKEN=ghp_xxxx
# GIT_HTTPS_USERNAME=x-access-token
# 概览「打开仓库」：无索引任务中的 repo_url 时，与 project_id（如 group/repo）拼接成浏览器地址
# GITLAB_EXTERNAL_URL=https://gitlab.com

# Dify：用于生成功能说明 & 对话查询（二选一或都用）
DIFY_API_KEY=app-xxxx
DIFY_BASE_URL=https://api.dify.ai/v1
# LLM 供应商：openai（默认）| dify | azure_openai；也可在管理端「设置」覆盖
# LLM_PROVIDER=openai

# 或使用 OpenAI / Azure OpenAI 生成说明（不填 Dify 时生效）
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Azure OpenAI（推荐，优先于 Dify/OPENAI_*）：
# AZURE_OPENAI_API_KEY=<密钥>
# AZURE_OPENAI_ENDPOINT=https://<resource>.cognitiveservices.azure.com
# AZURE_OPENAI_VERSION=2024-05-01-preview
# AZURE_OPENAI_DEPLOYMENT=<部署名，与 Azure 门户中一致，如 gpt-4o、gpt-35-turbo>

# 数据目录（Docker 内默认为 /data）
DATA_DIR=./data

# 本地 Git 镜像（DATA_DIR/repos）磁盘控制：索引拉取前按「目录最久未更新」优先删除其它项目；当前任务目录永不删。0 表示不限制。
# REPOS_CACHE_MAX_GB=20
# REPOS_CACHE_MAX_COUNT=30

# 增量向量索引：设为 1 时，在已有 last_indexed_commit 且向量 id 为 gv2_* 的前提下，仅对 git diff 变更路径删/写向量（Wiki 与 describe 仍全量）
# INCREMENTAL_INDEX=1
# 单次任务强制全量（忽略增量）：FORCE_FULL_INDEX=1

# 管理后台 /admin/ 登录：设置 ADMIN_PASSWORD 后须登录才能使用控制台；JWT 不保护 /api/query 等业务接口
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-strong-password
# JWT_SECRET=随机长串（与 ADMIN_PASSWORD 同时必填）
# JWT_EXPIRE_MINUTES=1440

# Vite 管理端本地开发跨域（可选）：CORS_ORIGINS=http://localhost:5173
# CORS_ORIGINS=

# 静态 Wiki：索引成功后生成站点到 DATA_DIR/wiki_sites/<project_id>/site/
# WIKI_BACKEND=mkdocs          # mkdocs（默认，纯 Python）| starlight | vitepress（后两者需 Node.js + npm）
# WIKI_ENABLED=false
# SKIP_WIKI=1
# WIKI_KEEP_WORK=1
# WIKI_MAX_FILE_PAGES=5000
# WIKI_SYMBOL_ROWS_PER_FILE=4000
# Wiki 使用 starlight|vitepress 时 npm 镜像（优先 NPM_REGISTRY；或在环境中设 npm_config_registry / NPM_CONFIG_REGISTRY）
# NPM_REGISTRY=https://registry.npmmirror.com

# 嵌入供应商：ollama（默认）| openai
# EMBED_PROVIDER=ollama
# OpenAI 兼容嵌入（与上方对话用 OPENAI_* 独立，可指向不同网关）
# OPENAI_EMBED_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBED_API_KEY=sk-xxxx
# 向量嵌入模型：Ollama 为 Ollama 模型名；OpenAI 为 embeddings 模型名（如 text-embedding-3-small）
# EMBED_MODEL=intfloat/multilingual-e5-large
# Ollama embedding 服务地址（可填网关地址）
# OLLAMA_BASE_URL=http://localhost:11434
# Ollama 鉴权（可选，接入网关/代理时常用）
# OLLAMA_API_KEY=

# 索引时排除的仓库相对路径 glob（正斜杠）；多行用引号内换行，或单行用英文逗号分隔多条。与内置跳过目录（node_modules 等）叠加。管理端「设置 → 索引排除」可覆盖本变量。
# INDEX_EXCLUDE_PATTERNS=**/*.pb.go,generated/**/*

# 索引说明与静态 Wiki 生成语言：zh（默认）| en；也可在管理端「设置」中覆盖
# CONTENT_LANGUAGE=zh
