# GitLab（自建 + 私有仓库时 GITLAB_ACCESS_TOKEN 必填，需 read_repository 权限）
GITLAB_WEBHOOK_SECRET=your_webhook_secret
GITLAB_ACCESS_TOKEN=glpat-xxxx

# Dify：用于生成功能说明 & 对话查询（二选一或都用）
DIFY_API_KEY=app-xxxx
DIFY_BASE_URL=https://api.dify.ai/v1

# 或使用 OpenAI / Azure OpenAI 生成说明（不填 Dify 时生效）
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Azure OpenAI（推荐，优先于 Dify/OPENAI_*）：
# AZURE_OPENAI_API_KEY=<密钥>
# AZURE_OPENAI_ENDPOINT=https://<resource>.cognitiveservices.azure.com
# AZURE_OPENAI_VERSION=2024-05-01-preview
# AZURE_OPENAI_DEPLOYMENT=<部署名，与 Azure 门户中一致，如 gpt-4o、gpt-35-turbo>

# 数据目录（Docker 内默认为 /data）
DATA_DIR=./data

# 静态 Wiki：索引成功后生成站点到 DATA_DIR/wiki_sites/<project_id>/site/
# WIKI_BACKEND=mkdocs          # mkdocs（默认，纯 Python）| starlight | vitepress（后两者需 Node.js + npm）
# WIKI_ENABLED=false
# SKIP_WIKI=1
# WIKI_KEEP_WORK=1
# WIKI_MAX_FILE_PAGES=5000
# WIKI_SYMBOL_ROWS_PER_FILE=4000
# Wiki 使用 starlight|vitepress 时 npm 镜像（优先 NPM_REGISTRY；或在环境中设 npm_config_registry / NPM_CONFIG_REGISTRY）
# NPM_REGISTRY=https://registry.npmmirror.com

# 向量嵌入模型（需为 fastembed 支持的模型，默认 intfloat/multilingual-e5-large）
# EMBED_MODEL=intfloat/multilingual-e5-large
